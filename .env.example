# Database connection string (SQLite — no external server needed)
DATABASE_URL="file:./data/taskmanager.db"

# The public URL of the app (used by NextAuth for redirects and callbacks)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth secret — generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secret-here"

# AI provider API keys (optional — only needed for AI features)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# SMTP email configuration (optional — emails are silently skipped if not set)
# For local dev with Mailpit: use default values below (run via Docker Compose)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Task Manager <noreply@taskmanager.local>"
SMTP_SECURE="false"

# Socket.io realtime server port
SOCKET_PORT="3001"
NEXT_PUBLIC_SOCKET_PORT="3001"

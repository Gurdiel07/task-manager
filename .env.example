# Database connection string
# For local dev: use localhost:5432
# For Docker Compose: use the service name "postgres" as hostname
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskmanager?schema=public"

# Redis connection string
# For local dev: use localhost:6379
# For Docker Compose: use the service name "redis" as hostname
REDIS_URL="redis://localhost:6379"

# The public URL of the app (used by NextAuth for redirects and callbacks)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth secret — generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secret-here"

# AI provider API keys (optional — only needed for AI features)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# SMTP email configuration (optional — emails are silently skipped if not set)
# For local dev with Mailpit: use default values below (run via Docker Compose)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Task Manager <noreply@taskmanager.local>"
SMTP_SECURE="false"

# Socket.io realtime server port
SOCKET_PORT="3001"
NEXT_PUBLIC_SOCKET_PORT="3001"
